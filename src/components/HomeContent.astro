---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { ui, localizedPath, formatDate } from '../i18n.js';
const { lang = 'tr' } = Astro.props;
const t = ui[lang];
const h = t.home;
const L = (p) => localizedPath(p, lang);

// Latest 3 build-log posts in this language, for the home page sidebar.
const recentPosts = (await getCollection('buildlog'))
  .filter((p) => p.id.startsWith(`${lang}/`))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const postSlug = (id) => id.replace(/^(tr|en)\//, '');
---
<Base title={h.title} desc={h.desc} lang={lang}>

  <header class="hero" id="top">
    <div class="wrap hero-row">
      <div class="hero-in">
        <span class="eyebrow">{h.eyebrow}</span>
        <h1><span class="gold">PHALANX</span> RACING</h1>
        <p class="sub">{h.sub}</p>
        <p class="tag">{h.tag}</p>
        <div class="cta">
          <a href="#road" class="btn solid">{h.ctaRoad}</a>
          <a href={L('/build-log')} class="btn">{h.ctaLog}</a>
        </div>
        <a href={L('/takim')} class="btn flow">{h.teamCta}</a>
      </div>

      <aside class="news-side">
        <div class="news-blk">
          <div class="news-h">{h.sideRecent}</div>
          {recentPosts.map((p) => (
            <a class="news-item" href={L(`/build-log/${postSlug(p.id)}/`)}>
              <div class="news-date">{formatDate(p.data.date, lang)}</div>
              <div class="news-t">{p.data.title}</div>
              {p.data.summary && <p class="news-s">{p.data.summary}</p>}
            </a>
          ))}
          <a class="news-all" href={L('/build-log')}>{h.sideAllLog}</a>
        </div>
        <div class="news-blk">
          <div class="news-h">{h.sideUpcoming}</div>
          {h.upcoming.map((u) => (
            <div class="news-item">
              <div class="news-date">{u.date}</div>
              <div class="news-t">{u.title}</div>
              <p class="news-s">{u.place}</p>
            </div>
          ))}
        </div>
      </aside>
    </div>
  </header>

  <div class="stats"><div class="wrap stats-in">
    {h.stats.map((s) => (
      <div class="stat"><div class="n gold">{s.n}</div><div class="k">{s.k}</div></div>
    ))}
  </div></div>

  <section class="blk" id="road">
    <div class="wrap">
      <div class="sec-head"><span class="eyebrow">{h.roadEyebrow}</span><h2>{h.roadHead}</h2></div>
      <div class="road">
        {h.phases.map((ph) => (
          <div class={ph.mile ? 'phase mile' : 'phase'}>
            <div class="p">{ph.p}</div>
            <h3>{ph.h}</h3>
            <p>{ph.d}{ph.hl && <b class="hl">{ph.hl}</b>}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="blk" id="sponsor">
    <div class="wrap">
      <div class="sec-head"><span class="eyebrow">{h.sponsorEyebrow}</span><h2>{h.sponsorHead}</h2></div>
      <div class="tiers">
        {h.tiers.map((tier) => (
          <div class={tier.feat ? 'tier feat' : 'tier'}>
            <div class="t">{tier.t}</div>
            <ul>{tier.items.map((it) => <li>{it}</li>)}</ul>
          </div>
        ))}
      </div>
      <div class="support"><b>{h.supportBold}</b>{h.supportRest}</div>
    </div>
  </section>

  <section class="blk alt" id="contact">
    <div class="wrap contact-in">
      <span class="eyebrow">{h.contactEyebrow}</span>
      <h2>{h.contactHead}</h2>
      <p>{h.contactText}</p>
      <a class="mail" href="mailto:info.phalanxracing@gmail.com">info.phalanxracing@gmail.com</a>
      <p class="uni">{h.uni}</p>
      <a class="btn solid" href="mailto:info.phalanxracing@gmail.com">{h.contactBtn}</a>
    </div>
  </section>

<style>
:global(body){
  background-image:linear-gradient(180deg,rgba(13,17,20,.5),rgba(13,17,20,.62)),url('/hero-bg.jpg');
  background-size:cover,cover;
  background-position:center,center;
  background-repeat:no-repeat,no-repeat;
  background-attachment:fixed,fixed;
}
@media(max-width:820px),(hover:none){
  :global(body){background-attachment:scroll,scroll}
}
.hero{position:relative;min-height:88vh;display:flex;align-items:center;overflow:hidden}
.hero-row{display:flex;align-items:flex-start;justify-content:space-between;gap:48px;flex-wrap:wrap;padding:60px 22px}
.hero-in{position:relative;z-index:2;max-width:640px;text-align:left}

.hero h1{font-size:clamp(44px,8vw,92px);line-height:.98;font-weight:700;text-transform:uppercase;margin:14px 0 8px}
.hero h1 .gold{background:linear-gradient(105deg,#B37E27 0%,#D8A93E 26%,#F3E29A 44%,#FCF3CE 50%,#F3E29A 56%,#D8A93E 74%,#B37E27 100%);background-size:300% auto;-webkit-background-clip:text;background-clip:text;color:transparent;animation:shimmer 6s linear infinite}
@keyframes shimmer{from{background-position:300% center}to{background-position:0% center}}
@media(prefers-reduced-motion:reduce){.hero h1 .gold{animation:none}}
.hero .sub{font-family:'Chakra Petch';font-size:clamp(15px,2.2vw,20px);color:var(--cream);letter-spacing:.04em}
.hero .tag{color:var(--muted);max-width:540px;margin:16px 0 30px;font-size:16px}
.hero .cta{display:flex;gap:14px;flex-wrap:wrap;justify-content:flex-start}

.btn.flow{
  display:inline-block;margin-top:14px;position:relative;overflow:hidden;
  border:1px solid var(--gold);color:var(--yellow);font-weight:700;
  text-shadow:0 1px 4px rgba(0,0,0,.9),0 0 10px rgba(0,0,0,.6);
  box-shadow:0 0 22px rgba(188,131,41,.4);
  background-color:#17110a;
  background-image:
    linear-gradient(rgba(8,6,3,.35),rgba(8,6,3,.35)),
    repeating-linear-gradient(45deg,#D8A93E 0,#D8A93E 14px,#17110a 14px,#17110a 28px);
  background-position:0 0,0 0;
  background-size:100% 100%,auto;
  background-repeat:no-repeat,repeat;
  animation:flowstripe 2.6s linear infinite;
}
.btn.flow:hover{
  border-color:var(--yellow);box-shadow:0 0 28px rgba(188,131,41,.6);color:var(--yellow);
  background-image:
    linear-gradient(rgba(8,6,3,.2),rgba(8,6,3,.2)),
    repeating-linear-gradient(45deg,#F0ED72 0,#F0ED72 14px,#17110a 14px,#17110a 28px);
}
@keyframes flowstripe{from{background-position:0 0,0 0}to{background-position:0 0,39.6px 0}}
@media(prefers-reduced-motion:reduce){.btn.flow{animation:none}}

.news-side{position:relative;z-index:2;flex:0 0 260px;padding:0;display:flex;flex-direction:column;gap:30px}
.news-blk{display:flex;flex-direction:column;gap:16px}
.news-h{font-family:'Chakra Petch';text-transform:uppercase;letter-spacing:.16em;font-weight:700;font-size:13px;color:var(--gold)}
.news-item{display:block;color:inherit;text-decoration:none}
.news-date{font-family:'Chakra Petch';font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
.news-t{font-size:15px;font-weight:600;color:var(--cream);margin-top:2px;transition:color .2s}
a.news-item:hover .news-t{color:var(--yellow)}
.news-s{font-size:13px;color:var(--muted);margin-top:3px}
.news-all{align-self:flex-start;font-family:'Chakra Petch';font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--gold);text-decoration:none}
.news-all:hover{color:var(--yellow)}

.stats{border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
.stats-in{display:grid;grid-template-columns:repeat(4,1fr)}
.stat{padding:26px 18px;text-align:center;border-right:1px solid var(--line)}
.stat:last-child{border-right:0}
.stat .n{font-family:'Chakra Petch';font-size:34px;font-weight:700}
.stat .k{font-size:12px;text-transform:uppercase;letter-spacing:.16em;color:var(--muted);margin-top:4px}

.blk{padding:84px 0}
.alt{background:linear-gradient(180deg,rgba(13,17,20,.58) 0%,rgba(22,15,31,.58) 50%,rgba(13,17,20,.58) 100%)}
.sec-head{margin-bottom:40px}
.sec-head h2{font-size:clamp(28px,5vw,44px);text-transform:uppercase;font-weight:700;margin-top:8px}

.road{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:16px}
.phase{border:1px solid var(--line);padding:22px;background:rgba(38,26,50,.35)}
.phase .p{font-family:'Chakra Petch';font-size:12px;letter-spacing:.14em;color:var(--gold);text-transform:uppercase}
.phase h3{font-size:19px;margin:8px 0;text-transform:uppercase;font-weight:600}
.phase p{font-size:14px;color:var(--muted)}
.phase .hl{color:var(--yellow);font-weight:600}
.phase.mile{border-color:var(--yellow);background:rgba(240,237,114,.06)}
.phase.mile .p{color:var(--yellow)}

.tiers{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:16px;margin-bottom:26px}
.tier{border:1px solid var(--line);padding:26px 22px;background:rgba(38,26,50,.35)}
.tier.feat{border:1px solid var(--gold);background:rgba(188,131,41,.08)}
.tier .t{font-family:'Chakra Petch';text-transform:uppercase;letter-spacing:.14em;font-weight:700;font-size:20px}
.tier.feat .t{color:var(--yellow)}
.tier ul{list-style:none;margin-top:16px}
.tier li{font-size:14px;color:var(--muted);padding:7px 0;border-bottom:1px solid rgba(188,131,41,.14)}
.support{border:1px dashed var(--line);padding:20px;font-size:14px;color:var(--muted)}
.support b{color:var(--cream);font-weight:600}

.contact-in{text-align:center;max-width:640px;margin:0 auto}
.contact-in h2{margin:8px 0 14px}
.contact-in p{color:var(--muted);margin-bottom:14px}
.contact-in .mail{display:block;color:var(--gold);font-family:'Chakra Petch';letter-spacing:.06em;font-size:20px;margin-bottom:10px}
.contact-in .uni{font-size:13px;margin-bottom:22px}

@media(max-width:640px){
  .stats-in{grid-template-columns:repeat(2,1fr)}
  .stat:nth-child(2){border-right:0}
  .stat{border-bottom:1px solid var(--line)}
}
</style>
</Base>
