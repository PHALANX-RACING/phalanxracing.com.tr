---
import { getCollection } from 'astro:content';
import PostContent from '../../components/PostContent.astro';

export async function getStaticPaths() {
  const posts = await getCollection('buildlog');
  return posts
    .filter((post) => post.id.startsWith('tr/'))
    .map((post) => ({ params: { slug: post.id.replace(/^tr\//, '') }, props: { post } }));
}

const { post } = Astro.props;
---
<PostContent lang="tr" post={post} />
