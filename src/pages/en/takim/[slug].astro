---
import MemberContent from '../../../components/MemberContent.astro';
import { people } from '../../../data/team.js';

export function getStaticPaths() {
  return people().map((p) => ({ params: { slug: p.slug }, props: { person: p } }));
}

const { person } = Astro.props;
---
<MemberContent lang="en" person={person} />
