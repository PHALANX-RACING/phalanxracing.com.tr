---
import '../styles/global.css';
const { title = 'Phalanx Racing', desc = 'TEKNOFEST 2027 Efficiency Challenge — elektrikli verimlilik aracı geliştiren öğrenci takımı' } = Astro.props;
const path = Astro.url.pathname;
---
<!doctype html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={desc} />
  <link rel="icon" type="image/svg+xml" href="/logo.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <nav>
    <div class="wrap nav-in">
      <a class="brand" href="/"><img src="/logo.svg" alt="" class="brand-logo" /><span class="brand-txt">PHALANX<small>RACING</small></span></a>
      <button class="burger" id="burger" aria-label="Menü">&#9776;</button>
      <div class="links" id="links">
        <a href="/#road">Yol Haritası</a>
        <a href="/build-log" class={path.startsWith('/build-log') ? 'active' : ''}>Build-log</a>
        <a href="/takim" class={path.startsWith('/takim') ? 'active' : ''}>Takım</a>
        <a href="/#sponsor">Sponsorlar</a>
        <a href="/#contact">İletişim</a>
      </div>
    </div>
  </nav>
  <main><slot /></main>
  <footer>
    <img src="/logo.svg" alt="Phalanx Racing" style="height:52px;width:auto;margin:0 auto 12px;display:block;opacity:.9" />
    <div>© 2026 Phalanx Racing · TEKNOFEST 2027 Efficiency Challenge</div>
  </footer>
  <script>
    const b = document.getElementById('burger');
    const l = document.getElementById('links');
    b && b.addEventListener('click', () => l && l.classList.toggle('open'));
    l && l.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => l.classList.remove('open')));
  </script>
</body>
</html>
